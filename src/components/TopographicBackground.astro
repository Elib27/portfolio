---
---

<div class="animation-canvas-container animated">
  <canvas class="animation-canvas"></canvas>
</div>

<style lang="scss">
  .animation-canvas-container {
    height: 100vh;
    width: 100%;
    overflow: hidden;
    position: absolute;
    top: 0;
    left: 0;
    z-index: -1;
    -webkit-mask-image: linear-gradient(
      to right,
      rgba(0, 0, 0, 1) 50%,
      transparent 60%
    );
    -webkit-mask-size: 250% 100%;
    -webkit-mask-position: left;
    transition: -webkit-mask-position 1s linear 0.4s;
    pointer-events: none;
    &.animated {
      -webkit-mask-position: right;
    }
    .animation-canvas {
      display: block;
      width: 100%;
      height: 100%;
      opacity: 0;
      transition: opacity 0.8s ease;
      -webkit-mask-image: linear-gradient(
        rgba(0, 0, 0, 1) 80%,
        transparent 100%
      );
    }
  }
</style>

<script>
  import * as THREE from 'three';

  // == GLSL Shaders ===========================================================

  const vertexShader = `
    varying vec2 vUv;
    void main() {
      vUv = uv;
      gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    }
  `;

  const fragmentShader = `
    uniform float uTime;
    uniform vec2 uResolution;
    uniform vec2 uMouse;
    uniform float uMouseStrength;
    uniform float uMouseRadius;
    uniform float uNoiseScale;
    uniform int uLevels;
    uniform float uLineWidth;
    uniform float uOpacityDeep;
    uniform vec3 uColorDeep;
    uniform vec3 uColorShallow;
    uniform float uDpr;

    varying vec2 vUv;

    // Simplex 2D noise
    vec3 permute(vec3 x) { return mod(((x*34.0)+1.0)*x, 289.0); }

    float snoise(vec2 v) {
      const vec4 C = vec4(0.211324865405187, 0.366025403784439,
               -0.577350269189626, 0.024390243902439);
      vec2 i  = floor(v + dot(v, C.yy) );
      vec2 x0 = v -   i + dot(i, C.xx);
      vec2 i1;
      i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
      vec4 x12 = x0.xyxy + C.xxzz;
      x12.xy -= i1;
      i = mod(i, 289.0);
      vec3 p = permute( permute( i.y + vec3(0.0, i1.y, 1.0 ))
        + i.x + vec3(0.0, i1.x, 1.0 ));
      vec3 m = max(0.5 - vec3(dot(x0,x0), dot(x12.xy,x12.xy),
        dot(x12.zw,x12.zw)), 0.0);
      m = m*m ;
      m = m*m ;
      vec3 x = 2.0 * fract(p * C.www) - 1.0;
      vec3 h = abs(x) - 0.5;
      vec3 ox = floor(x + 0.5);
      vec3 a0 = x - ox;
      m *= 1.79284291400159 - 0.85373472095314 * ( a0*a0 + h*h );
      vec3 g;
      g.x  = a0.x  * x0.x  + h.x  * x0.y;
      g.yz = a0.yz * x12.xz + h.yz * x12.yw;
      return 130.0 * dot(m, g);
    }

    void main() {
      vec2 st = vUv * uResolution; // Physical pixels
      vec2 stLog = st / uDpr;      // Logical pixels
      
      // Calculate height field using logical pixels to match original scale
      float h = snoise(vec2(stLog.x * uNoiseScale + uTime, stLog.y * uNoiseScale + uTime * 0.7)) * 0.65;
      h += snoise(vec2(stLog.x * uNoiseScale * 2.1 + uTime * 1.3, stLog.y * uNoiseScale * 2.1)) * 0.35;
      h = h * 0.5 + 0.5;

      // Mouse Gaussian bump (using logical pixels for distance and radius)
      vec2 mousePosLog = uMouse / uDpr;
      float dLog = distance(stLog, mousePosLog);
      float mouseRLog = (uResolution.x / uDpr) * uMouseRadius;
      h += 0.72 * exp(-(dLog * dLog) / (mouseRLog * mouseRLog)) * uMouseStrength;

      // Define contour ranges
      float minLevel = 0.08;
      float maxLevel = 0.92;
      float range = maxLevel - minLevel;
      float stepSize = range / float(uLevels - 1);

      vec4 finalColor = vec4(0.0);

      // We calculate how much h changes per physical pixel for accurate line width
      float grad = length(vec2(dFdx(h), dFdy(h)));

      // Optimized: find the nearest contour level
      float levelIndex = floor((h - minLevel) / stepSize + 0.5);
      
      if (levelIndex >= 0.0 && levelIndex < float(uLevels)) {
        float lt = levelIndex / float(uLevels - 1);
        float level = minLevel + levelIndex * stepSize;

        // Distance to the iso-value in physical pixels
        float dist = abs(h - level) / grad;
        
        // Line mask using smoothstep for antialiasing
        float lineMask = 1.0 - smoothstep(uLineWidth * 0.5, uLineWidth * 0.5 + 1.0, dist);

        if (lineMask > 0.0) {
          vec3 color = mix(uColorShallow, uColorDeep, lt);
          float opacityShallow = uOpacityDeep * 0.18;
          float alpha = mix(opacityShallow, uOpacityDeep, lt);
          
          finalColor = vec4(color, lineMask * alpha);
        }
      }

      gl_FragColor = finalColor;
    }
  `;

  // == Config =================================================================

  const params = {
    timeSpeed:     0.00003,
    noiseScale:    0.0028,
    levels:        16,
    mouseRadius:   0.08,
    mouseStrength: 0.72,
    lineWidth:     0.9,
    opacityDeep:   0.7,
  }

  const COLOR_DEEP    = new THREE.Color(0x585efb);
  const COLOR_SHALLOW = new THREE.Color(0xa5b4fc);

  // == Three.js Setup =========================================================

  const container = document.querySelector('.animation-canvas-container') as HTMLDivElement;
  const canvas    = document.querySelector('.animation-canvas') as HTMLCanvasElement;

  const renderer = new THREE.WebGLRenderer({
    canvas,
    alpha: true,
    antialias: true,
  });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2)); // Limit pixel ratio for performance

  const scene = new THREE.Scene();
  const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);

  const geometry = new THREE.PlaneGeometry(2, 2);
  const uniforms = {
    uTime: { value: 0 },
    uResolution: { value: new THREE.Vector2() },
    uMouse: { value: new THREE.Vector2(-9999, -9999) },
    uMouseStrength: { value: 0 },
    uMouseRadius: { value: params.mouseRadius },
    uNoiseScale: { value: params.noiseScale },
    uLevels: { value: params.levels },
    uLineWidth: { value: params.lineWidth },
    uOpacityDeep: { value: params.opacityDeep },
    uColorDeep: { value: COLOR_DEEP },
    uColorShallow: { value: COLOR_SHALLOW },
    uDpr: { value: renderer.getPixelRatio() },
  };

  const material = new THREE.ShaderMaterial({
    uniforms,
    vertexShader,
    fragmentShader,
    transparent: true,
  });

  const mesh = new THREE.Mesh(geometry, material);
  scene.add(mesh);

  function resize() {
    const width = container.clientWidth;
    const height = container.clientHeight;
    renderer.setSize(width, height, true);
    
    // Get actual pixel dimensions for the shader
    const pixelWidth = canvas.width;
    const pixelHeight = canvas.height;
    uniforms.uResolution.value.set(pixelWidth, pixelHeight);
  }
  resize();
  window.addEventListener('resize', resize);

  // == Mouse ==================================================================

  let mouseX = -9999, mouseY = -9999;
  let smoothX = -9999, smoothY = -9999;
  let mouseStrength = 0;
  let isInside = false;

  const section = document.querySelector('#home') as HTMLElement;

  section?.addEventListener('mousemove', (e) => {
    const rect = canvas.getBoundingClientRect();
    const dpr = renderer.getPixelRatio();
    mouseX = (e.clientX - rect.left) * dpr;
    mouseY = (rect.height - (e.clientY - rect.top)) * dpr; // Flip Y for GLSL
    isInside = true;
  });
  section?.addEventListener('mouseleave', () => { isInside = false; });

  function advanceMouse() {
    mouseStrength += isInside
      ? Math.min(0.04, 1 - mouseStrength)
      : -Math.min(0.025, mouseStrength);
    mouseStrength = Math.max(0, Math.min(1, mouseStrength));

    if (smoothX === -9999) { smoothX = mouseX; smoothY = mouseY; }
    smoothX += (mouseX - smoothX) * 0.055;
    smoothY += (mouseY - smoothY) * 0.055;

    uniforms.uMouse.value.set(smoothX, smoothY);
    uniforms.uMouseStrength.value = mouseStrength;
  }

  // == Render loop ============================================================

  const startTime = performance.now();

  function frame() {
    const t = (performance.now() - startTime) * params.timeSpeed;
    uniforms.uTime.value = t;

    // Update uLineWidth with current DPR (in case it changes or for consistency)
    const dpr = renderer.getPixelRatio();
    uniforms.uLineWidth.value = params.lineWidth * dpr;

    advanceMouse();
    renderer.render(scene, camera);
    requestAnimationFrame(frame);
  }

  // == Startup ================================================================

  function startAnimation() {
    canvas.style.opacity = '1';
    requestAnimationFrame(frame);
  }

  if (!container.classList.contains('animated')) {
    startAnimation();
  } else {
    const observer = new MutationObserver(() => {
      if (!container.classList.contains('animated')) {
        observer.disconnect();
        startAnimation();
      }
    });
    observer.observe(container, { attributes: true, attributeFilter: ['class'] });
  }
</script>
