---
import { getLangFromUrl, useTranslations } from '../i18n/utils'
import ToggleThemeButton from '../components/ToggleThemeButton.astro'
import Logo from '../components/Logo.astro'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const langLink = lang === 'en' ? 'fr' : 'en'

const navItems = [
  { href: '#about', label: t('nav.about'), section: 'about' },
  { href: '#projects', label: t('nav.projects'), section: 'projects' },
  { href: '#contact', label: t('nav.contact'), section: 'contact' },
]
---

<header class="navbar">
  <div class="navbar__inner">
    <Logo link="#" />

    <nav class="navbar__desktop animated" aria-label="Main navigation">
      <div class="navbar__indicator"></div>
      <ul>
        {navItems.map(({ href, label, section }) => (
          <li>
            <a href={href} data-section={section}>{label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="navbar__actions animated">
      <a class="navbar__lang" href={`/${langLink === 'en' ? '' : langLink}`} aria-label={`Switch to ${langLink}`}>
        {langLink}
      </a>
      <ToggleThemeButton id="desktop" />
    </div>

    <div class="navbar__mobile-actions animated">
      <a class="navbar__lang" href={`/${langLink === 'en' ? '' : langLink}`} aria-label={`Switch to ${langLink}`}>
        {langLink}
      </a>
      <ToggleThemeButton id="mobile" />
      <button class="navbar__hamburger" aria-expanded="false" aria-label="Toggle menu">
        <span class="line"></span>
        <span class="line"></span>
        <span class="line"></span>
      </button>
    </div>
  </div>
</header>

<nav class="mobile-nav" aria-label="Mobile navigation">
  <ul>
    {navItems.map(({ href, label }, i) => (
      <li style={`--delay: ${0.05 + i * 0.05}s`}>
        <a href={href}>{label}</a>
      </li>
    ))}
  </ul>
  <div class="mobile-nav__footer" style="--delay: 0.2s">
    <a class="navbar__lang" href={`/${langLink === 'en' ? '' : langLink}`}>
      {langLink}
    </a>
    <ToggleThemeButton id="mobile-nav" />
  </div>
</nav>

<style lang="scss">
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 999;
    padding: 1rem 2rem;
    pointer-events: none;
    transform: translateY(0);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);

    &.is-hidden {
      transform: translateY(-100%);
    }

    &__inner {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      max-width: 1400px;
      margin: 0 auto;
    }
  }

  .animated {
    transform: translateY(20px);
    transition: transform 1s cubic-bezier(0, 0, 0.16, 1) 0.4s;
  }

  // Desktop nav pill
  .navbar__desktop {
    pointer-events: all;
    position: relative;
    display: flex;
    align-items: center;
    padding: 0.35rem 0.4rem;
    background: color-mix(in srgb, var(--nav-background) 70%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid color-mix(in srgb, var(--text) 8%, transparent);
    border-radius: 50px;
    box-shadow:
      0 4px 24px rgba(0, 0, 0, 0.06),
      0 1px 2px rgba(0, 0, 0, 0.04);
    transition:
      background-color var(--theme-transition),
      border-color var(--theme-transition),
      box-shadow var(--theme-transition),
      transform 1s cubic-bezier(0, 0, 0.16, 1) 0.4s;

    ul {
      display: flex;
      gap: 0.2rem;
      list-style: none;
      padding: 0;
      margin: 0;
      position: relative;
    }

    li a {
      display: block;
      font-weight: 600;
      font-size: 0.88rem;
      padding: 0.5rem 1rem;
      border-radius: 50px;
      white-space: nowrap;
      line-height: 1.2;
      color: color-mix(in srgb, var(--text) 85%, transparent);
      transition:
        color var(--theme-transition),
        background-color var(--theme-transition);

      &:hover {
        color: var(--text);
        background: color-mix(in srgb, var(--text) 6%, transparent);
      }

      &.is-active {
        color: var(--text);
      }
    }
  }

  // Sliding active indicator
  .navbar__indicator {
    position: absolute;
    height: calc(100% - 0.7rem);
    border-radius: 50px;
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 20%, transparent);
    pointer-events: none;
    opacity: 0;
    transition:
      left 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      width 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.2s ease;

    &.is-visible {
      opacity: 1;
    }
  }

  // Right side actions (desktop)
  .navbar__actions {
    pointer-events: all;
    display: flex;
    align-items: center;
    justify-self: end;
    gap: 1rem;
    padding: 0.5rem 0.8rem;
    background: color-mix(in srgb, var(--nav-background) 70%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid color-mix(in srgb, var(--text) 8%, transparent);
    border-radius: 50px;
    box-shadow:
      0 4px 24px rgba(0, 0, 0, 0.06),
      0 1px 2px rgba(0, 0, 0, 0.04);
    transition:
      background-color var(--theme-transition),
      border-color var(--theme-transition),
      transform 1s cubic-bezier(0, 0, 0.16, 1) 0.4s;
  }

  // Language toggle
  .navbar__lang {
    text-transform: uppercase;
    font-size: 0.85rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.05em;
    padding: 0.3rem 0.4rem;
    border-radius: 6px;
    transition:
      color var(--theme-transition),
      background-color var(--theme-transition);

    &:hover {
      background: color-mix(in srgb, var(--text) 8%, transparent);
    }
  }

  // Mobile actions (hamburger group)
  .navbar__mobile-actions {
    pointer-events: all;
    display: none;
    align-items: center;
    justify-self: end;
    gap: 1.2rem;
    transition: transform 1s cubic-bezier(0, 0, 0.16, 1) 0.4s;
  }

  // Hamburger
  .navbar__hamburger {
    height: 28px;
    width: 32px;
    background: transparent;
    border: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;

    .line {
      height: 3px;
      width: 100%;
      background-color: var(--text);
      border-radius: 2px;
      transition:
        transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
        opacity 0.2s ease,
        background-color var(--theme-transition);
      transform-origin: center;
    }

    &.is-open {
      .line:nth-child(1) {
        transform: translateY(12.5px) rotate(45deg);
      }
      .line:nth-child(2) {
        opacity: 0;
        transform: scaleX(0);
      }
      .line:nth-child(3) {
        transform: translateY(-12.5px) rotate(-45deg);
      }
    }
  }

  // Mobile full-screen nav
  .mobile-nav {
    position: fixed;
    inset: 0;
    z-index: 998;
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background: color-mix(in srgb, var(--nav-background) 95%, transparent);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.35s ease,
      visibility 0.35s ease,
      background var(--theme-transition);

    &.is-open {
      opacity: 1;
      visibility: visible;

      ul li {
        opacity: 1;
        transform: translateY(0);
      }

      .mobile-nav__footer {
        opacity: 1;
        transform: translateY(0);
      }
    }

    ul {
      list-style: none;
      padding: 0;
      margin: 0;
      text-align: center;

      li {
        opacity: 0;
        transform: translateY(20px);
        transition:
          opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1) var(--delay),
          transform 0.4s cubic-bezier(0.16, 1, 0.3, 1) var(--delay);
      }

      a {
        display: inline-block;
        font-family: 'Space Grotesk', sans-serif;
        font-size: 2.6rem;
        font-weight: 600;
        line-height: 1;
        padding: 0.8rem 1rem;
        border-radius: 12px;
        transition:
          color var(--theme-transition),
          background-color var(--theme-transition);

        &:hover {
          background: color-mix(in srgb, var(--text) 6%, transparent);
        }
      }
    }

    &__footer {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      margin-top: 3rem;
      opacity: 0;
      transform: translateY(20px);
      transition:
        opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1) var(--delay),
        transform 0.4s cubic-bezier(0.16, 1, 0.3, 1) var(--delay);
    }
  }

  // Responsive
  @media (max-width: 768px) {
    .navbar__desktop,
    .navbar__actions {
      display: none;
    }
    .navbar__mobile-actions {
      display: flex;
    }
    .mobile-nav {
      display: flex;
    }
  }

  @media (max-width: 480px) {
    .navbar {
      padding: 0.6rem 1.2rem;
    }
  }
</style>

<script>
  // --- Hamburger & mobile nav ---
  const hamburger = document.querySelector<HTMLButtonElement>('.navbar__hamburger')
  const mobileNav = document.querySelector<HTMLElement>('.mobile-nav')

  function toggleMobileNavigation() {
    hamburger?.classList.toggle('is-open')
    mobileNav?.classList.toggle('is-open')
    document.body.classList.toggle('no-scroll')

    const expanded = hamburger?.getAttribute('aria-expanded') === 'true'
    hamburger?.setAttribute('aria-expanded', String(!expanded))
  }

  hamburger?.addEventListener('click', toggleMobileNavigation)

  document.querySelectorAll<HTMLAnchorElement>('.mobile-nav a[href^="#"]')
    .forEach((link) => link.addEventListener('click', toggleMobileNavigation))

  // --- Hide on scroll down, show on scroll up ---
  const navbar = document.querySelector<HTMLElement>('.navbar')
  let lastScrollY = window.scrollY
  let ticking = false

  function updateNavbarVisibility() {
    const currentScrollY = window.scrollY
    if (currentScrollY > 100 && currentScrollY > lastScrollY) {
      navbar?.classList.add('is-hidden')
    } else {
      navbar?.classList.remove('is-hidden')
    }
    lastScrollY = currentScrollY
    ticking = false
  }

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(updateNavbarVisibility)
      ticking = true
    }
  }, { passive: true })

  // --- Active section tracking ---
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('.navbar__desktop a[data-section]')
  const indicator = document.querySelector<HTMLElement>('.navbar__indicator')
  const sections = document.querySelectorAll<HTMLElement>('section[id], div[id="about"], div[id="projects"], div[id="contact"]')

  function updateIndicator(activeLink: HTMLAnchorElement | null) {
    if (!indicator || !activeLink) {
      indicator?.classList.remove('is-visible')
      return
    }

    const nav = indicator.parentElement!
    const navRect = nav.getBoundingClientRect()
    const linkRect = activeLink.getBoundingClientRect()

    indicator.style.left = `${linkRect.left - navRect.left}px`
    indicator.style.width = `${linkRect.width}px`
    indicator.classList.add('is-visible')
  }

  function setActiveLink(sectionId: string | null) {
    navLinks.forEach((link) => {
      const isActive = link.dataset.section === sectionId
      link.classList.toggle('is-active', isActive)
      if (isActive) updateIndicator(link)
    })

    if (!sectionId) updateIndicator(null)
  }

  // IntersectionObserver for sections
  const sectionIds = ['about', 'projects', 'contact']
  const sectionElements = sectionIds
    .map((id) => document.getElementById(id))
    .filter(Boolean) as HTMLElement[]

  // Track which sections are currently visible
  const visibleSections = new Set<string>()
  let currentSection: string | null = null

  function pickActiveSection() {
    if (visibleSections.size === 0) {
      const firstSection = sectionElements[0]
      if (firstSection && window.scrollY < firstSection.offsetTop - 200) {
        if (currentSection !== null) {
          currentSection = null
          setActiveLink(null)
        }
      }
      return
    }

    // Pick the first (topmost) visible section in DOM order
    const newSection = sectionIds.find((id) => visibleSections.has(id)) ?? null
    if (newSection !== currentSection) {
      currentSection = newSection
      setActiveLink(newSection)
    }
  }

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          visibleSections.add(entry.target.id)
        } else {
          visibleSections.delete(entry.target.id)
        }
      }
      pickActiveSection()
    },
    {
      threshold: [0, 0.15],
      rootMargin: '-20% 0px -40% 0px',
    }
  )

  sectionElements.forEach((section) => observer.observe(section))

  // Also update indicator on resize
  window.addEventListener('resize', () => {
    const active = document.querySelector<HTMLAnchorElement>('.navbar__desktop a.is-active')
    if (active) updateIndicator(active)
  })
</script>
