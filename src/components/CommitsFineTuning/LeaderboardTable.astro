---
import leaderboard from '../../data/leaderboard.json'

type Metrics = Record<string, number>
type Row = { name: string; metrics: Metrics }

const entries = Object.entries(leaderboard as Record<string, Metrics>)

// Metric columns are derived from the data keys (order preserved from the JSON).
const metricKeys = entries.length > 0 ? Object.keys(entries[0][1]) : []

// The full entry key is kept as the row name (e.g. "Qwen2.5-Coder-0.5B-Instruct_baseline").
const rows: Row[] = entries.map(([name, metrics]) => ({ name, metrics }))

// Highest value per metric column (bolded in the table).
const maxByKey: Record<string, number> = {}
for (const key of metricKeys) {
  maxByKey[key] = Math.max(...rows.map((r) => r.metrics[key] ?? -Infinity))
}

// Initial order so the table reads meaningfully before any click.
const initialSortKey = 'total_score'
const sortedRows = [...rows].sort(
  (a, b) => (b.metrics[initialSortKey] ?? 0) - (a.metrics[initialSortKey] ?? 0)
)

const isPercent = (key: string) => key.endsWith('%')

function formatMetric(key: string, value: number): string {
  if (isPercent(key)) return `${(value * 100).toFixed(1)}%`
  return value.toFixed(3)
}
---

<div class="leaderboard-wrap">
  <table class="leaderboard">
    <thead>
      <tr>
        <th data-key="model" data-type="string" scope="col" tabindex="0">
          <span class="th-inner"><span class="th-label">Model</span><span class="th-arrow" aria-hidden="true" /></span>
        </th>
        {
          metricKeys.map((key) => (
            <th
              data-key={key}
              data-type="number"
              class:list={['numeric', key === initialSortKey && 'sorted-desc']}
              aria-sort={key === initialSortKey ? 'descending' : 'none'}
              scope="col"
              tabindex="0"
            >
              <span class="th-inner">
                <span class="th-label">{key}</span>
                <span class="th-arrow" aria-hidden="true" />
              </span>
            </th>
          ))
        }
      </tr>
    </thead>
    <tbody>
      {
        sortedRows.map((row) => (
          <tr>
            <td data-value={row.name} class="col-model">{row.name}</td>
            {metricKeys.map((key) => (
              <td
                data-value={String(row.metrics[key] ?? '')}
                class:list={['numeric', row.metrics[key] === maxByKey[key] && 'is-best']}
              >
                {formatMetric(key, row.metrics[key])}
              </td>
            ))}
          </tr>
        ))
      }
    </tbody>
  </table>
</div>

<style lang="scss">
  .leaderboard-wrap {
    margin: 2rem 0;
    overflow-x: auto;
  }
  .leaderboard {
    /* `display: table` overrides the global `.prose table { display: block }`, so
       the wrapper is the single horizontal-scroll container (no nested scroll). */
    display: table;
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    white-space: nowrap;

    th {
      position: sticky;
      top: 0;
      cursor: pointer;
      user-select: none;
      font-weight: 700;
      padding: 0.55rem 0.9rem;
      background: var(--background);
      border-bottom: 2px solid color-mix(in srgb, var(--accent) 40%, transparent);
      transition: color var(--theme-transition), background-color var(--theme-transition);

      &:hover {
        color: var(--accent);
      }
      &.sorted-asc,
      &.sorted-desc {
        color: var(--accent);
      }
      &:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: -2px;
      }
    }

    .th-inner {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
    }
    th.numeric .th-inner {
      flex-direction: row-reverse;
    }
    .th-arrow::after {
      content: '↕';
      opacity: 0.35;
      font-size: 0.85em;
    }
    .sorted-asc .th-arrow::after {
      content: '↑';
      opacity: 1;
    }
    .sorted-desc .th-arrow::after {
      content: '↓';
      opacity: 1;
    }

    td {
      padding: 0.5rem 0.9rem;
      border-bottom: 1px solid color-mix(in srgb, var(--text) 12%, transparent);
    }
    tbody tr:last-child td {
      border-bottom: none;
    }
    tbody tr:hover td {
      background: color-mix(in srgb, var(--text) 4%, transparent);
    }

    th.numeric,
    td.numeric {
      text-align: right;
      font-variant-numeric: tabular-nums;
    }
    .col-model {
      font-weight: 600;
    }
    td.is-best {
      font-weight: 700;
    }
  }
</style>

<script>
  const table = document.querySelector<HTMLTableElement>('table.leaderboard')

  if (table) {
    const tbody = table.querySelector('tbody')!
    const headers = Array.from(table.querySelectorAll<HTMLTableCellElement>('thead th'))

    let activeKey = 'total_score' // matches the build-time initial sort
    let activeDir: 'asc' | 'desc' = 'desc'

    function sortBy(key: string, type: string, dir: 'asc' | 'desc') {
      const index = headers.findIndex((h) => h.dataset.key === key)
      if (index < 0) return
      const rows = Array.from(tbody.querySelectorAll('tr'))
      rows.sort((a, b) => {
        const av = a.children[index]?.getAttribute('data-value') ?? ''
        const bv = b.children[index]?.getAttribute('data-value') ?? ''
        const cmp =
          type === 'number' ? Number(av) - Number(bv) : av.localeCompare(bv)
        return dir === 'asc' ? cmp : -cmp
      })
      rows.forEach((row) => tbody.appendChild(row))
    }

    function updateIndicators() {
      headers.forEach((h) => {
        const isActive = h.dataset.key === activeKey
        h.classList.toggle('sorted-asc', isActive && activeDir === 'asc')
        h.classList.toggle('sorted-desc', isActive && activeDir === 'desc')
        h.setAttribute(
          'aria-sort',
          isActive ? (activeDir === 'asc' ? 'ascending' : 'descending') : 'none'
        )
      })
    }

    headers.forEach((th) => {
      const handleSort = () => {
        const key = th.dataset.key
        const type = th.dataset.type ?? 'string'
        if (!key) return
        if (activeKey === key) {
          activeDir = activeDir === 'asc' ? 'desc' : 'asc'
        } else {
          activeKey = key
          activeDir = type === 'number' ? 'desc' : 'asc' // numbers default high→low
        }
        sortBy(key, type, activeDir)
        updateIndicators()
      }
      th.addEventListener('click', handleSort)
      th.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault()
          handleSort()
        }
      })
    })

    updateIndicators()
  }
</script>
