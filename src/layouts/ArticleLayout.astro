---
import Layout from './Layout.astro'
import ToggleThemeButton from '../components/ToggleThemeButton.astro'

export interface Props {
  frontmatter: {
    title: string
    description?: string
    date?: string
    draft?: boolean
  }
}

const { frontmatter } = Astro.props
const { title, description, date, draft } = frontmatter
---

<Layout noIndex={draft}>
  <header class="article-topbar">
    <a class="back" href="/#projects" aria-label="Back to portfolio">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
      <span>Portfolio</span>
    </a>
    <ToggleThemeButton id="article" />
  </header>

  <main class="article-main">
    <article class="prose">
      <div class="article-header">
        <div class="badges">
          <span class="badge">Project</span>
          {draft && <span class="badge">Draft</span>}
        </div>
        <h1>{title}</h1>
        {description && <p class="lead">{description}</p>}
        {date && <p class="date">{date}</p>}
      </div>
      <slot />
    </article>
  </main>
</Layout>

<style lang="scss">
  .article-topbar {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.5rem;
    max-width: 820px;
    margin: 0 auto;
    width: 100%;
    background: color-mix(in srgb, var(--background) 80%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: background-color var(--theme-transition);

    .back {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      line-height: 1;
      font-weight: 600;
      font-size: 0.95rem;
      color: var(--text);
      padding: 0.4rem 0.6rem;
      border-radius: 8px;
      transition: background-color var(--theme-transition);
      &:hover {
        background: color-mix(in srgb, var(--text) 8%, transparent);
      }
      svg {
        color: var(--text);
      }
    }
  }

  .article-main {
    max-width: 820px;
    margin: 0 auto;
    padding: 2rem 1.5rem 6rem;
  }

  .article-header {
    margin-bottom: 3rem;
    .badges {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 1rem;
    }
    .badge {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent);
      border: 1px solid color-mix(in srgb, var(--accent) 40%, transparent);
      background: color-mix(in srgb, var(--accent) 12%, transparent);
      padding: 0.25rem 0.6rem;
      border-radius: 50px;
    }
    h1 {
      font-size: clamp(2rem, 5vw, 3rem);
      line-height: 1.1;
      margin: 0 0 1rem;
    }
    .lead {
      font-size: 1.2rem;
      line-height: 1.6;
      color: color-mix(in srgb, var(--text) 75%, transparent);
    }
    .date {
      margin-top: 0.8rem;
      font-size: 0.9rem;
      color: color-mix(in srgb, var(--text) 55%, transparent);
    }
  }
</style>

<style lang="scss" is:global>
  .prose {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--text);
    transition: color var(--theme-transition);

    h2 {
      font-size: 1.7rem;
      line-height: 1.25;
      margin: 3rem 0 1rem;
      scroll-margin-top: 5rem;
    }
    h3 {
      font-size: 1.3rem;
      margin: 2.2rem 0 0.8rem;
    }
    p {
      font-size: inherit;
      line-height: inherit;
      margin: 0 0 1.3rem;
    }
    a:not(.back) {
      color: var(--accent);
      text-decoration: underline;
      text-underline-offset: 3px;
      line-height: inherit;
    }
    ul,
    ol {
      margin: 0 0 1.3rem;
      padding-left: 1.4rem;
      li {
        margin-bottom: 0.5rem;
        &::marker {
          color: color-mix(in srgb, var(--accent) 80%, var(--text));
        }
      }
    }
    strong {
      font-weight: 700;
    }
    blockquote {
      margin: 1.5rem 0;
      padding: 0.5rem 1.2rem;
      border-left: 3px solid var(--accent);
      background: color-mix(in srgb, var(--accent) 7%, transparent);
      border-radius: 0 8px 8px 0;
      color: color-mix(in srgb, var(--text) 80%, transparent);
      p:last-child {
        margin-bottom: 0;
      }
    }
    hr {
      border: none;
      border-top: 1px solid color-mix(in srgb, var(--text) 12%, transparent);
      margin: 3rem 0;
    }
    img {
      max-width: 100%;
      height: auto;
      border-radius: 12px;
      margin: 1.5rem 0;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin: 0 0 1.5rem;
      font-size: 0.95rem;
      display: block;
      overflow-x: auto;
      th,
      td {
        padding: 0.6rem 0.9rem;
        text-align: left;
        border-bottom: 1px solid color-mix(in srgb, var(--text) 12%, transparent);
      }
      th {
        font-weight: 700;
        border-bottom: 2px solid color-mix(in srgb, var(--accent) 40%, transparent);
      }
      tbody tr:last-child td {
        border-bottom: none;
      }
    }

    code {
      font-family: ui-monospace, 'SF Mono', Menlo, monospace;
      font-size: 0.88em;
      background: color-mix(in srgb, var(--text) 8%, transparent);
      padding: 0.15em 0.4em;
      border-radius: 5px;
    }
    pre {
      background: #0c0d2a;
      color: #e6e6f0;
      padding: 1.2rem 1.4rem;
      border-radius: 12px;
      overflow-x: auto;
      margin: 0 0 1.5rem;
      border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
      font-size: 0.85rem;
      line-height: 1.6;
      code {
        background: none;
        padding: 0;
        font-size: inherit;
      }
    }
  }
</style>
